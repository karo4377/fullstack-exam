# Backend — copy to .env and fill in real values (never commit .env)

# Local Postgres (docker compose: port 5433 on the host)
DATABASE_URL="postgresql://artshop:artshop@localhost:5433/artshop"

# Or your hosted DB (Neon, Render Postgres, etc.) — use in Render env, or locally for migrate/seed
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

JWT_SECRET="change-me-in-production"

# Local Next.js
FRONTEND_URL="http://localhost:3000"

# Production (set in Render dashboard)
# FRONTEND_URL="https://fullstack-exam-weld.vercel.app"

PORT=3001
NODE_ENV=development
